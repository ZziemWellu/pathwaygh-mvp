# PathwayGH Environment Variables
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://pathwaygh:password@localhost:5432/pathwaygh

# Redis
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://pathwaygh-frontend.onrender.com

# AI Services
OPENAI_API_KEY=your_openai_api_key_here
USE_AI_CHATBOT=true

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
